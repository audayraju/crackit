{
  "name": "crackai",
  "version": "1.0.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:electron": "electron .",
    "dev:desktop": "concurrently \"npm run dev\" \"npm run dev:electron\"",
    "build:desktop": "electron-builder --win"
  },
  "build": {
    "appId": "com.crackai.desktop",
    "productName": "CrackAI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "next": "^14.2.0",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
